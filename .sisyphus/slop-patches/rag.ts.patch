+import { getToken } from '../utils/token'
+import { apiClientConfig } from '../core/config'
+
+/**
+ * 鐢熸垚鍞竴浼氳瘽 ID锛氭祻瑙堝櫒鎸囩汗 + 鏃堕棿鎴?+ * 鎸囩汗鍩轰簬 navigator銆乻creen 绛夌幆澧冪壒寰侊紝纭繚鍚屼竴娴忚鍣ㄧ敓鎴愬浐瀹氬墠缂€
+ */
+export function generateConversationId(): string {
+  const fp = [
+    navigator.userAgent,
+    screen.width,
+    screen.height,
+    navigator.language,
+    navigator.hardwareConcurrency ?? '',
+  ].join('|')
+
+  let hash = 0
+  for (let i = 0; i < fp.length; i++) {
+    hash = ((hash << 5) - hash) + fp.charCodeAt(i)
+    hash |= 0
+  }
+  const fpHash = Math.abs(hash).toString(36).slice(0, 6)
+  const timestamp = Date.now().toString(36)
+
+  return `conv-${fpHash}-${timestamp}`
+}
+
+/** 鏉ユ簮淇℃伅锛堥€傞厤鍚庣杩斿洖鏍煎紡锛?*/
+export interface Source {
+  /** 鍚庣杩斿洖鐨勬枃浠跺悕 */
+  filename: string
+  /** 鏄剧ず鏍囬锛屼紭鍏堝彇 excerpt 涓В鏋愮殑鏍囬锛屽惁鍒欑敤 filename */
+  title: string
+  /** 閾炬帴锛堝悗绔彲鑳戒笉杩斿洖锛?*/
+  url?: string
+  /** 鎽樿鍐呭 */
+  content?: string
+  /** 鐩稿叧搴﹀垎鏁?*/
+  relevanceScore?: number
+}
+
+export interface AskStreamParams {
+  question: string
+  conversationId: string
+  maxResults?: number
+}
+
+export interface SSEEventHandlers {
+  onStart: (conversationId: string) => void
+  onDelta: (content: string) => void
+  onSources: (sources: Source[]) => void
+  onComplete: () => void
+  onCancelled: () => void
+  onError: (message: string) => void
+}
+
+export interface HealthStatus {
+  status: string
+  [key: string]: unknown
+}
+
+/**
+ * 鍙戦€侀棶棰樺苟閫氳繃 SSE 娴佸紡鎺ユ敹鍥炵瓟
+ * 浣跨敤鍘熺敓 fetch + ReadableStream 澶勭悊 POST 璇锋眰鐨?SSE 娴?+ */
+export async function askStream(
+  params: AskStreamParams,
+  handlers: SSEEventHandlers,
+  signal?: AbortSignal,
+) {
+  const response = await fetch(`${apiClientConfig.baseURL}/api/rag/ask/stream`, {
+    method: 'POST',
+    headers: {
+      'Content-Type': 'application/json',
+      ...getAuthHeaders(),
+    },
+    body: JSON.stringify({
+      question: params.question,
+      conversationId: params.conversationId,
+      maxResults: params.maxResults ?? 5,
+    }),
+    signal,
+  })
+
+  if (!response.ok) {
+    throw new Error(`HTTP ${response.status}: ${response.statusText}`)
+  }
+
+  const reader = response.body!.getReader()
+  const decoder = new TextDecoder()
+  let buffer = ''
+  let currentEvent = ''
+
+  while (true) {
+    const { done, value } = await reader.read()
+
+    if (value) {
+      buffer += decoder.decode(value, { stream: true })
+
+      const lines = buffer.split('\n')
+      buffer = lines.pop() || ''
+
+      for (const line of lines) {
+        const trimmed = line.trim()
+        if (!trimmed) continue
+
+        // 鍏煎 event:xxx 鍜?event: xxx 涓ょ鏍煎紡
+        if (trimmed.startsWith('event:')) {
+          currentEvent = trimmed.slice(6).trim()
+        } else if (trimmed.startsWith('data:')) {
+          const raw = trimmed.slice(5).trim()
+          try {
+            const data = JSON.parse(raw)
+            switch (currentEvent) {
+              case 'start':
+                handlers.onStart(data.conversationId)
+                break
+              case 'delta':
+                handlers.onDelta(data.content ?? data ?? '')
+                break
+              case 'sources': {
+                const rawSources: unknown[] = Array.isArray(data) ? data : (data.sources ?? [])
+                const mapped = rawSources.map((s: unknown): Source => {
+                  const item = s as Record<string, unknown>
+                  const excerpt = String(item.excerpt ?? '')
+
+                  // 浠?excerpt 涓彁鍙栥€愭钀藉叧閿瘝锛歺xx銆戜綔涓烘洿鍏蜂綋鐨勬弿杩?+                  const keywordsMatch = excerpt.match(/銆愭钀藉叧閿瘝锛?.+?)銆?)
+                  // 浠?excerpt 涓彁鍙栥€愭爣棰橈細xxx銆戜綔涓烘枃妗ｆ爣棰?+                  const titleMatch = excerpt.match(/銆愭爣棰橈細(.+?)銆?)
+
+                  const filename = String(item.filename ?? '')
+                  const keywords = keywordsMatch?.[1]
+                  const docTitle = titleMatch?.[1]
+
+                  // 浼樺厛鐢ㄥ叧閿瘝锛堟洿鍏蜂綋锛夛紝鍏舵鐢ㄦ枃妗ｆ爣棰橈紝鏈€鍚庣敤鏂囦欢鍚?+                  const displayTitle = keywords
+                    ? `${filename} 鈥?${keywords}`
+                    : (docTitle ?? filename) || '鏈煡鏉ユ簮'
+
+                  return {
+                    filename,
+                    title: displayTitle,
+                    url: item.url as string | undefined,
+                    content: excerpt,
+                    relevanceScore: item.relevanceScore as number | undefined,
+                  }
+                })
+                handlers.onSources(mapped)
+                break
+              }
+                break
+              case 'complete':
+                handlers.onComplete()
+                break
+              case 'cancelled':
+                handlers.onCancelled()
+                break
+              case 'error':
+                handlers.onError(data.message || 'Unknown error')
+                break
+            }
+          } catch {
+            // data 涓嶆槸 JSON锛屼綔涓虹函鏂囨湰鍐呭澶勭悊锛堝搴?delta 閫愬瓧鎺ㄩ€侊級
+            if (currentEvent === 'delta') {
+              handlers.onDelta(raw)
+            }
+          }
+        }
+      }
+    }
+
+    if (done) break
+  }
+
+  // 娴佺粨鏉熸椂鍏滃簳閲嶇疆鐘舵€侊紝澶勭悊鍚庣涓嶆樉寮忓彂閫?complete 浜嬩欢鐨勬儏鍐?+  handlers.onComplete()
+}
+
+/** 鑾峰彇璁よ瘉澶?*/
+function getAuthHeaders(): Record<string, string> {
+  const token = getToken()
+  return token ? { Authorization: `Bearer ${token}` } : {}
+}
+
+/** 鍋滄 AI 鐢熸垚 */
+export async function cancelConversation(conversationId: string) {
+  const response = await fetch(
+    `${apiClientConfig.baseURL}/api/rag/conversations/${conversationId}/cancel`,
+    { method: 'POST', headers: { ...getAuthHeaders() } },
+  )
+  // 404 琛ㄧず鍚庣宸叉棤杩涜涓换鍔★紙SSE 鏂紑鏃惰嚜鍔ㄥ彇娑堬紝鎴栧凡鎻愬墠缁撴潫锛夛紝灞炴甯告儏鍐?+  if (response.status === 404) return
+  if (!response.ok) {
+    throw new Error(`鍙栨秷鐢熸垚澶辫触: HTTP ${response.status}`)
+  }
+}
+
+/** 鍒犻櫎浼氳瘽 */
+export async function deleteConversation(conversationId: string) {
+  const response = await fetch(
+    `${apiClientConfig.baseURL}/api/rag/conversations/${conversationId}`,
+    { method: 'DELETE', headers: { ...getAuthHeaders() } },
+  )
+  if (!response.ok) {
+    throw new Error(`鍒犻櫎浼氳瘽澶辫触: HTTP ${response.status}`)
+  }
+}
+
+/** 鑾峰彇 RAG 鏈嶅姟鍋ュ悍鐘舵€?*/
+export async function getHealth(): Promise<HealthStatus> {
+  try {
+    const response = await fetch(`${apiClientConfig.baseURL}/api/rag/health`)
+    const text = await response.text()
+    return { status: text.includes('姝ｅ父') ? 'ok' : 'error' }
+  } catch {
+    return { status: 'error' }
+  }
+}
